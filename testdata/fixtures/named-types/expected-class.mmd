classDiagram
    class Code["Code"] {
        <<type>>
        type int
    }
    class Index["Index"] {
        <<map>>
        type Map~string,*Item~
    }
    class Item["Item"] {
        +Name string
    }
    class ItemAlias["ItemAlias"] {
        <<alias>>
        type Item
    }
    class Items["Items"] {
        <<slice>>
        type Item[]
        +Len() int
    }
    class Sizer["Sizer"] {
        <<interface>>
        +Len() int
    }
    class Transform["Transform"] {
        <<func>>
        type func
    }
    class Vector["Vector"] {
        <<array>>
        type Array~4,Item~
    }
    class hidden["hidden"] {
        <<slice>>
        type Item[]
    }
    class secret["secret"] {
        +Item Item
    }
    Index ..> Item : *
    ItemAlias ..> Item
    Items ..> Item : *
    Items ..|> Sizer
    Transform ..> Index
    Transform ..> Items
    Vector ..> Item : *
    hidden ..> Item : *
    secret ..> Item
