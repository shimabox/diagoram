<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; object-src 'none'; base-uri 'none'; form-action 'none'">
<title>diagoram portal</title>
<link rel="stylesheet" href="assets/style.css">
</head>
<body>
<header>
  <h1>diagoram portal</h1>
  <dl class="meta">
    <div>
      <dt>Directory</dt>
      <dd>{{.Dir}}</dd>
    </div>
    <div>
      <dt>Module</dt>
      <dd>{{if .ModulePath}}{{.ModulePath}}{{else}}not detected{{end}}</dd>
    </div>
    <div>
      <dt>diagoram version</dt>
      <dd>{{.Version}}</dd>
    </div>
  </dl>
</header>
<main>
  <div class="cards">
    <a class="card" href="type-diagram.html">
      <h2>Types and relationships</h2>
      <p>Structs, interfaces, and named types with their dependencies, rendered with Mermaid.</p>
    </a>
    <a class="card" href="package-diagram.html">
      <h2>Package diagram</h2>
      <p>Package dependencies, rendered with Mermaid.</p>
    </a>
    <a class="card" href="type-diagram-puml.html">
      <h2>Types and relationships (PlantUML source)</h2>
      <p>PlantUML source for offline SVG conversion.</p>
    </a>
    <a class="card" href="package-diagram-puml.html">
      <h2>Package diagram (PlantUML source)</h2>
      <p>PlantUML source for offline SVG conversion.</p>
    </a>
    <a class="card" href="report.html">
      <h2>Report</h2>
      <p>Markdown analysis report with settings, structural summary, and diagram.</p>
    </a>
    <a class="card" href="summary.html">
      <h2>Summary</h2>
      <p>Plain-text structural summary of the analyzed types.</p>
    </a>
  </div>
</main>
</body>
</html>
